<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Axiora SaaS</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-50 min-h-screen font-sans">

    <nav class="bg-slate-900 text-white p-4 shadow-md flex justify-between items-center">
        <h1 class="text-xl font-bold">Axiora Knowledge Engine</h1>
        <div class="flex items-center gap-4">
            <span class="text-sm text-slate-300">Welcome, <%= username %></span>
            <button id="logoutBtn" class="bg-red-600 hover:bg-red-700 px-4 py-2 rounded text-sm font-semibold transition">Log Out</button>
        </div>
    </nav>

    <main class="max-w-6xl mx-auto p-6 grid grid-cols-1 lg:grid-cols-3 gap-8 mt-6">
        
        <div class="lg:col-span-1 flex flex-col gap-6">
            
            <div class="bg-white p-6 rounded-xl shadow border border-gray-100">
                <h2 class="text-lg font-bold text-slate-800 mb-2">1. Feed the Engine</h2>
                <p class="text-sm text-gray-500 mb-4">Add a new URL to train the AI.</p>
                
                <form id="ingestForm" class="flex flex-col gap-3">
                    <input type="url" id="targetUrl" placeholder="https://..." required class="w-full border border-gray-300 p-2 rounded focus:ring-2 focus:ring-blue-600 outline-none">
                    <button type="submit" id="ingestBtn" class="w-full bg-blue-600 text-white font-bold py-2 px-4 rounded hover:bg-blue-700 transition">
                        Ingest Data
                    </button>
                </form>
                <div id="ingestStatus" class="mt-3 text-sm hidden font-mono p-2 rounded bg-slate-100"></div>
            </div>

            <div class="bg-white p-6 rounded-xl shadow border border-gray-100">
                <h2 class="text-lg font-bold text-slate-800 mb-2">2. Embed the Widget</h2>
                <p class="text-sm text-gray-500 mb-4">Paste this into the bottom of any HTML page.</p>
                
                <div class="relative">
                    <textarea readonly class="w-full h-24 bg-slate-900 text-green-400 font-mono text-xs p-3 rounded outline-none resize-none overflow-hidden">
                        <script src="http://localhost:3000/public/widget.js" data-user="<%= userId %>"></script>
                    </textarea>
                </div>
            </div>
        </div>

        <div class="lg:col-span-2">
            <div class="bg-white p-6 rounded-xl shadow border border-gray-100 h-full">
                <h2 class="text-lg font-bold text-slate-800 mb-4">Your Knowledge Bases</h2>
                
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-slate-50 border-b border-gray-200">
                                <th class="p-3 text-sm font-semibold text-slate-600">URL Source</th>
                                <th class="p-3 text-sm font-semibold text-slate-600">Status</th>
                                <th class="p-3 text-sm font-semibold text-slate-600">Date Added</th>
                                <th class="p-3 text-sm font-semibold text-slate-600 text-right">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (knowledgeBases.length === 0) { %>
                                <tr>
                                    <td colspan="3" class="p-6 text-center text-gray-400 text-sm">No data sources added yet.</td>
                                </tr>
                            <% } else { %>
                                <% knowledgeBases.forEach(function(kb) { %>
                                    <tr class="border-b border-gray-100 hover:bg-slate-50">
                                        <td class="p-3 text-sm text-slate-800 truncate max-w-[200px]"><%= kb.scraped_url %></td>
                                        <td class="p-3">
                                            <span class="px-2 py-1 text-xs font-semibold rounded-full 
                                                <%= kb.status === 'success' ? 'bg-green-100 text-green-700' : 'bg-yellow-100 text-yellow-700' %>">
                                                <%= kb.status.toUpperCase() %>
                                            </span>
                                        </td>
                                        <td class="p-3 text-sm text-gray-500"><%= new Date(kb.created_at).toLocaleDateString() %></td>
                                        <td class="p-3 text-right flex justify-end gap-2">
                                            <button onclick="resyncUrl('<%= kb.scraped_url %>')" class="text-blue-600 hover:text-blue-800 text-sm font-semibold px-2 py-1 rounded hover:bg-blue-50 transition">
                                                Resync
                                            </button>
                                            <button onclick="deleteKb('<%= kb.id %>')" class="text-red-600 hover:text-red-800 text-sm font-semibold px-2 py-1 rounded hover:bg-red-50 transition">
                                                Delete
                                            </button>
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        </div>
            <div class="bg-white p-6 rounded-xl shadow border border-gray-100 mt-6 h-[400px] flex flex-col">
                <h2 class="text-lg font-bold text-slate-800 mb-2">3. Test Playground</h2>
                <p class="text-sm text-gray-500 mb-4">Interact with the AI engine using the ingested data.</p>
                
                <div class="border border-gray-200 rounded-lg overflow-hidden flex flex-col flex-1 bg-slate-50">
                    <div id="testChatWindow" class="flex-1 p-4 overflow-y-auto flex flex-col gap-3">
                        <div class="bg-white border border-gray-200 text-slate-800 p-3 rounded-lg rounded-tl-none self-start max-w-[85%] shadow-sm text-sm">
                            System Online. The database is connected. What would you like to know?
                        </div>
                    </div>
                    <div class="p-3 bg-white border-t border-gray-200 flex gap-2">
                        <input type="text" id="testChatInput" placeholder="Query the database..." autocomplete="off" class="flex-1 border border-gray-300 p-2 rounded focus:ring-2 focus:ring-blue-600 outline-none text-sm">
                        <button id="testChatBtn" class="bg-slate-900 text-white font-bold py-2 px-4 rounded hover:bg-slate-800 transition text-sm">Send</button>
                    </div>
                </div>
                <input type="hidden" id="hiddenUserId" value="<%= userId %>">
            </div>
        </div>
    </main>

    <script src="/dashboardLogic.js"></script>
</body>
</html>